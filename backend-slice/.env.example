# Supabase Postgres — Transaction mode pooler (port 6543) — used at runtime
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Supabase Postgres — Direct connection (port 5432) — used for migrations
DATABASE_URL_UNPOOLED="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

JWT_SECRET="dev-only-change-me-in-prod-2bb6a4c7"
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7
PORT=4000
NODE_ENV=development

# Supabase storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-me"
STORAGE_BUCKET="macro-attachments"

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:3000
